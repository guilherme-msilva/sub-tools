# ─────────────────────────────────────────────────────────────────────────────
# Sub-Tools — Configuration Template
#
# Copy or rename this file to ".env" and fill in your values.
# All settings can also be changed via the application GUI (Settings and
# Keywords dialogs) — no manual editing required after the initial setup.
#
# Get a free API key at: https://www.opensubtitles.com/en/api
# ─────────────────────────────────────────────────────────────────────────────


# ── Credentials ───────────────────────────────────────────────────────────────

# [REQUIRED] API key generated at opensubtitles.com → Profile → API Consumers
MY_API_KEY='LEY3jHoShl7DsAEWmngYWEUnzdEmwG5s'

# [OPTIONAL] Your opensubtitles.com account username or e-mail.
# Providing a valid account raises the daily download limit from ~5 to ~200.
MY_USERNAME=

# [OPTIONAL] Your opensubtitles.com account password.
# Required only when MY_USERNAME is set.
MY_PASSWORD=


# ── Subtitle Language ─────────────────────────────────────────────────────────

# Language code for subtitle search. This value is set automatically when
# you change the language via the dropdown in the GUI.
#
# Common codes:
#   pt-br  Portuguese (Brazilian)
#   pt     Portuguese (European)
#   en     English
#   es     Spanish
#   fr     French
#   de     German
#   it     Italian
#   ja     Japanese
#   ko     Korean
#   zh-cn  Chinese Simplified
#   ar     Arabic
#   ru     Russian
MY_LANGUAGE=pt-br


# ── Download Behavior ─────────────────────────────────────────────────────────

# Skip video files that already have a matching .srt in the same folder.
#   1 = skip (default)
#   0 = download anyway and save with a language-code suffix (e.g. movie.en.srt)
SKIP_EXISTING=1


# ── Auto-Sync (Alass Integration) ─────────────────────────────────────────────

# Automatically run Clean → Alass sync right after each subtitle download.
# Requires the Alass executable to be present in the "alass-windows64" folder.
#   0 = disabled (default)
#   1 = enabled  (pipeline: Download → Clean with confirmation → Alass sync)
AUTO_SYNC=0


# ── Ad Filter Keywords ────────────────────────────────────────────────────────

# Comma-separated list of keywords used to detect advertisement subtitle blocks.
# Subtitle blocks whose text contains any of these words (case-insensitive)
# will be flagged for removal during the Clean Subtitles operation.
# This value is managed via the "Keywords" button in the GUI.
#
# Default keywords (used when this value is empty):
#   opensubtitles, vip, .com, .org, bet, casino, cassino,
#   propaganda, anúncio, subtitles, advertise
AD_KEYWORDS_LIST=opensubtitles,vip,.com,.org,bet,casino,cassino,propaganda,anúncio,subtitles,advertise
